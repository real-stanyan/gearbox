#!/usr/bin/env node
// gearbox-prune — branch hygiene: clean up merged/stale branches (fourth tool in the family, ADR-0030)
//
// Usage: run `gearbox-prune` from any git repo root (or subdirectory), or `npx gearbox-agents prune`
//   (default)          dry-run: list what would be cleaned up + settings check, deletes nothing
//   --apply-local     execute local merged-branch cleanup via `git branch -d` + `git fetch --prune`
//   --apply-remote    execute remote merged-branch cleanup via `git push origin --delete` (prints list + interactive confirm)
//   --yes             skip the --apply-remote interactive confirm (non-TTY / CI scenarios)
//   --check-settings  only check the `delete_branch_on_merge` repo setting (needs the gh CLI)
//
// Hard constraints (ADR-0030, must not be relaxed):
//   - force-delete (-D) is forever forbidden — force-delete discards unmerged work
//   - only touches merged branches; unmerged branches are never touched, even if the name looks stale (protects in-progress task branches)
//   - allowlist protection: current branch / default branch (main/master) / `gearbox-backfill-*` prefix
//   - never auto-changes GitHub repo settings — `delete_branch_on_merge` is only read + suggested as an opt-in command
//   - not a git repo / no origin → fail loudly and exit, never silently
//   - `gh` not installed/not authenticated → degrade only the settings-check part; branch cleanup proceeds as normal (branch operations are plain git)
//
// Does not depend on gearbox protocol files — pure git/gh operations, usable in any repo.

import { execFileSync, spawnSync } from "node:child_process";
import { createInterface } from "node:readline";
import { argv, exit, stdin, stdout } from "node:process";

const C = {
  red: (s) => `\x1b[31m${s}\x1b[0m`,
  green: (s) => `\x1b[32m${s}\x1b[0m`,
  yellow: (s) => `\x1b[33m${s}\x1b[0m`,
  dim: (s) => `\x1b[2m${s}\x1b[0m`,
  bold: (s) => `\x1b[1m${s}\x1b[0m`,
  cyan: (s) => `\x1b[36m${s}\x1b[0m`,
};

function die(msg, hint = "") {
  console.error(C.red(`✗ ${msg}`));
  if (hint) console.error(`  ${C.dim(hint)}`);
  exit(1);
}

function git(args, opts = {}) {
  return execFileSync("git", args, { encoding: "utf8", ...opts }).trim();
}

function tryGit(args) {
  try {
    return git(args, { stdio: ["ignore", "pipe", "ignore"] });
  } catch {
    return null;
  }
}

// ============== Args ==============

const args = argv.slice(2);
const FLAGS = new Set([
  "--apply-local",
  "--apply-remote",
  "--yes",
  "--check-settings",
  "-h",
  "--help",
]);
for (const a of args) {
  if (!FLAGS.has(a)) die(`Unknown argument: ${a}`, "run gearbox-prune --help for usage");
}
const applyLocal = args.includes("--apply-local");
const applyRemote = args.includes("--apply-remote");
const yes = args.includes("--yes");
const settingsOnly = args.includes("--check-settings");

if (args.includes("-h") || args.includes("--help")) {
  console.log(`gearbox-prune — branch hygiene (ADR-0030)

  (default)          dry-run: list what would be deleted, deletes nothing
  --apply-local     delete local merged branches (git branch -d) + git fetch --prune
  --apply-remote    delete remote merged branches (git push origin --delete), prints the list then asks for interactive confirmation
  --yes             skip the --apply-remote confirmation (for CI / non-TTY use)
  --check-settings  only check the delete_branch_on_merge repo setting (needs the gh CLI)

Allowlist protection: current branch / default branch / gearbox-backfill-* prefix. Force-delete (-D) is never used.
Only deletes merged branches; unmerged branches are never touched.`);
  exit(0);
}

// ============== Preflight checks (fail loudly) ==============

if (!tryGit(["rev-parse", "--git-dir"])) {
  die("Current directory is not a git repo", "cd into the target repo and try again");
}
if (!tryGit(["remote", "get-url", "origin"])) {
  die("No origin remote", "this tool determines the default branch and remote branches via origin");
}

// Default branch: ask the remote first (authoritative — local origin/HEAD is a clone-time
// snapshot that can go stale, and judging "merged" against a stale default branch causes
// wrongful deletions), fall back offline to the local origin/HEAD, then fall back to probing main/master
let defaultBranch = null;
const lsRemoteHead = tryGit(["ls-remote", "--symref", "origin", "HEAD"]);
const remoteHeadMatch = lsRemoteHead && lsRemoteHead.match(/^ref: refs\/heads\/(\S+)\s+HEAD/m);
if (remoteHeadMatch) {
  defaultBranch = remoteHeadMatch[1];
} else {
  const originHead = tryGit(["symbolic-ref", "--short", "refs/remotes/origin/HEAD"]);
  if (originHead) {
    defaultBranch = originHead.replace(/^origin\//, "");
  } else {
    for (const cand of ["main", "master"]) {
      if (tryGit(["show-ref", "--verify", `refs/remotes/origin/${cand}`]) !== null) {
        defaultBranch = cand;
        break;
      }
    }
  }
}
if (!defaultBranch) {
  die(
    "Could not determine the default branch (origin/HEAD is not set, and there's no main/master on origin either)",
    "run `git remote set-head origin --auto` and try again",
  );
}

const currentBranch = tryGit(["branch", "--show-current"]) || "";

// Allowlist: current / default / main / master / in-progress backfill branches
function isProtected(branch) {
  return (
    branch === currentBranch ||
    branch === defaultBranch ||
    branch === "main" ||
    branch === "master" ||
    branch.startsWith("gearbox-backfill-")
  );
}

const hasGh = (() => {
  try {
    execFileSync("gh", ["--version"], { stdio: "ignore" });
    return true;
  } catch {
    return false;
  }
})();

// ============== Collect the lists ==============

// 1. Local merged branches (relative to origin/<default>)
function localMergedBranches() {
  const out = tryGit(["branch", "--merged", `origin/${defaultBranch}`, "--format=%(refname:short)"]);
  if (out === null) return [];
  return out.split("\n").filter((b) => b && !isProtected(b));
}

// 2. Stale remote-tracking refs (deleted on origin, local tracking ref still around)
//    `git fetch --prune --dry-run` prints " - [deleted] ... -> origin/<b>" to stderr
function staleTrackingRefs() {
  const r = spawnSync("git", ["fetch", "--prune", "--dry-run", "origin"], {
    encoding: "utf8",
  });
  if (r.status !== 0) return null; // fetch failed (e.g. offline): mark as unknown, not as "none"
  return ((r.stderr + r.stdout).match(/\[deleted\].*-> +\S+/g) || []).map((l) =>
    l.replace(/.*-> +/, ""),
  );
}

// 3. Remote merged branches: after fetching, determined via merge-base --is-ancestor
//    (the feature-request suggestion of using the gh api branches/:branch `merged` field
//     doesn't exist — that endpoint only has name/commit/protected; git's ancestor check
//     needs zero API calls and zero pagination, ADR-0030)
function remoteMergedBranches() {
  const out = tryGit([
    "for-each-ref",
    "refs/remotes/origin",
    "--format=%(refname:short)",
  ]);
  if (out === null) return [];
  const merged = [];
  for (const ref of out.split("\n").filter(Boolean)) {
    if (ref === "origin/HEAD" || ref === "origin") continue;
    const branch = ref.replace(/^origin\//, "");
    if (isProtected(branch)) continue;
    try {
      execFileSync(
        "git",
        ["merge-base", "--is-ancestor", ref, `origin/${defaultBranch}`],
        { stdio: "ignore" },
      );
      merged.push(branch);
    } catch {
      /* not merged → leave it alone */
    }
  }
  return merged;
}

// 4. delete_branch_on_merge setting (read-only; gh not installed → degrade with a hint)
function checkSettings() {
  if (!hasGh) {
    console.log(
      C.yellow("⚠ gh CLI not installed — skipping delete_branch_on_merge check") +
        C.dim("(run brew install gh and retry; branch cleanup is unaffected)"),
    );
    return;
  }
  let val;
  try {
    val = execFileSync(
      "gh",
      ["api", "repos/{owner}/{repo}", "--jq", ".delete_branch_on_merge"],
      { encoding: "utf8", stdio: ["ignore", "pipe", "pipe"] },
    ).trim();
  } catch {
    console.log(
      C.yellow("⚠ Could not read repo settings (gh not authenticated or no permission) — skipping check"),
    );
    return;
  }
  if (val === "true") {
    console.log(C.green("✓ delete_branch_on_merge = true (GitHub auto-deletes the head branch after merge)"));
  } else {
    console.log(C.yellow("⚠ delete_branch_on_merge = false — recommend the owner enable it (fixes this at the root, auto-deletes after merge):"));
    console.log(
      C.cyan("  gh api -X PATCH repos/{owner}/{repo} -F delete_branch_on_merge=true"),
    );
  }
}

// ============== Execute ==============

async function confirm(question) {
  if (yes) return true;
  if (!stdin.isTTY) {
    die(
      "--apply-remote needs interactive confirmation, but this is not a TTY",
      "add --yes to skip confirmation (for CI scenarios), or run interactively in a terminal",
    );
  }
  const rl = createInterface({ input: stdin, output: stdout });
  const answer = await new Promise((res) => rl.question(question, res));
  rl.close();
  return answer.trim().toLowerCase() === "y";
}

function listOrNone(items, color = C.yellow) {
  if (!items || items.length === 0) return console.log(C.dim("  (none)"));
  for (const b of items) console.log(`  ${color(b)}`);
}

async function main() {
  console.log(C.bold(`gearbox-prune — default branch origin/${defaultBranch}, current branch ${currentBranch || "(detached)"}`));
  console.log("");

  if (settingsOnly) {
    checkSettings();
    return;
  }

  if (applyRemote) {
    // Refresh the view before deleting remote branches — local tracking refs can be stale,
    // and push --delete against a stale list would hit branches that no longer exist
    execFileSync("git", ["fetch", "--prune", "origin"], {
      stdio: ["ignore", "ignore", "inherit"],
    });
  }

  const localMerged = localMergedBranches();
  const stale = staleTrackingRefs();
  const remoteMerged = remoteMergedBranches();

  // --- Local ---
  console.log(C.bold(`Local merged branches (safe to delete via git branch -d):`));
  listOrNone(localMerged);
  console.log("");
  console.log(C.bold("Stale remote-tracking refs (cleaned by git fetch --prune):"));
  if (stale === null) console.log(C.dim("  (fetch failed — offline? unknown)"));
  else listOrNone(stale);
  console.log("");

  if (applyLocal) {
    for (const b of localMerged) {
      // -d is a safe delete: only deletes merged branches; if a race makes it unmerged,
      // -d will fail loudly on its own
      git(["branch", "-d", b], { stdio: ["ignore", "pipe", "inherit"] });
      console.log(C.green(`✓ Deleted local ${b}`));
    }
    execFileSync("git", ["fetch", "--prune", "origin"], { stdio: "inherit" });
    console.log(C.green("✓ git fetch --prune done"));
    console.log("");
  }

  // --- Remote ---
  console.log(C.bold("Remote merged branches (git push origin --delete):"));
  listOrNone(remoteMerged);
  console.log("");

  if (applyRemote && remoteMerged.length > 0) {
    const ok = await confirm(
      C.yellow(`About to delete ${remoteMerged.length} merged branches on origin (irreversible). Continue? [y/N] `),
    );
    if (!ok) {
      console.log(C.dim("Cancelled, remote branches untouched."));
    } else {
      for (const b of remoteMerged) {
        execFileSync("git", ["push", "origin", "--delete", b], {
          stdio: ["ignore", "inherit", "inherit"],
        });
        console.log(C.green(`✓ Deleted remote ${b}`));
      }
      // Clean up local tracking refs now that the remote branches are gone
      execFileSync("git", ["fetch", "--prune", "origin"], { stdio: "ignore" });
    }
    console.log("");
  } else if (applyRemote) {
    console.log(C.dim("No remote branches to delete."));
    console.log("");
  }

  // --- Settings check ---
  checkSettings();

  if (!applyLocal && !applyRemote) {
    console.log("");
    console.log(
      C.dim("dry-run finished, nothing was deleted. --apply-local deletes local branches, --apply-remote deletes remote branches (needs confirmation)."),
    );
  }
}

await main();
