#!/usr/bin/env bash
# gearbox-version — check which Gearbox ADRs a downstream project has synced
#
# Usage: run `gearbox-version` from any downstream repo's root
#       (recommended: symlink onto PATH: ln -sf ~/Github/gearbox/scripts/gearbox-version ~/.local/bin/)
#
# Algorithm (ADR-0016, provenance-first — replaces the old scaffold-version's plain
# filename-number comparison):
# An upstream ADR-NNNN counts as "synced" iff:
#   a) the downstream has an ADR file with the **same slug** (scaffold-time copy, the
#      number can differ), or
#   b) any downstream ADR's text references that upstream number:
#      - text reference: "scaffold ADR-NNNN" / "Gearbox ADR-NNNN" (case-insensitive)
#      - URL reference: a link into the agents-md-scaffold or gearbox repo's adr/NNNN- path
# This clears a known false positive from the old script: a downstream ADR that happens to
# share the same number (e.g. dryrun's own 0011 = puppeteer ≠ upstream 0011 = subagent-system)
# is no longer counted as "synced".
#
# Hash stamp (ADR-0021): gearbox-update records the upstream file's sha256 (first 12 chars)
# in the provenance line when it copies a file. This script compares, for slug-matched
# copies, "the recorded hash vs the upstream file's current hash":
#   match → ✅; mismatch → ⚠️ upstream has been revised (drift); no stamp → ✅ as before,
#   counted in the legacy summary.
#
# Version summary (ADR-0023): upstream's latest tag vs downstream's `.gearbox-version` stamp,
# printed as one line — "upstream vX / local vY (behind by <segment>)". The summary isn't the
# source of truth — the per-ADR detail (plus hashes) is.
#
# Honesty boundary:
# - A downstream project that "evaluated and rejected a backfill" (closed an issue declining
#   it) is invisible to this script — it's still reported as "not synced".
#   Authoritative status is upstream DOWNSTREAM.md's "currently synced to" column; this script
#   is only a local quick-check.
# - Hash detection only reports "upstream changed" — it doesn't judge whether the change is
#   worth backfilling; drift in legacy copies (no stamp) and provenance-reference-style syncs
#   (not a copy) can't be detected.
#
# Upstream addressing (ADR-0027): env GEARBOX_DIR > local ~/Github/gearbox > .gearbox-upstream
# remote cache. A local path is read-only and never writes anything to downstream; a remote
# path shallow-clones upstream into ~/.cache/gearbox/ (cached outside the repo, never touches
# the downstream working tree). Offline while on the remote path → ⚠ skip the version check,
# exit 0.
#
# No dependencies beyond: plain bash + grep + ls + git (for remote addressing). Never writes
# any file in the downstream repo.

set -euo pipefail

RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
DIM=$'\033[2m'
RESET=$'\033[0m'

# ── Upstream addressing (ADR-0027): env > local default > .gearbox-upstream remote cache ──
DEFAULT_LOCAL="${GEARBOX_DIR:-$HOME/Github/gearbox}"
UPSTREAM_URL=""
[[ -f .gearbox-upstream ]] && UPSTREAM_URL=$(head -1 .gearbox-upstream | tr -d '[:space:]')
UPSTREAM_IS_REMOTE=0

if [[ -d "$DEFAULT_LOCAL/docs/gearbox-adr" ]]; then
  GEARBOX_DIR="$DEFAULT_LOCAL"                       # local upstream hit (a maintainer's own fleet takes this path)
elif [[ -n "$UPSTREAM_URL" ]]; then
  UPSTREAM_IS_REMOTE=1                               # unfamiliar fork: shallow-clone cache
  cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/gearbox"
  url_hash=$(printf '%s' "$UPSTREAM_URL" | shasum -a 256 | cut -c1-12)
  GEARBOX_DIR="$cache_root/$url_hash"
  if [[ -d "$GEARBOX_DIR/.git" ]]; then
    git -C "$GEARBOX_DIR" fetch -q --depth 1 origin 2>/dev/null \
      && git -C "$GEARBOX_DIR" reset -q --hard FETCH_HEAD 2>/dev/null \
      || { echo "${YELLOW}⚠ can't reach upstream ($UPSTREAM_URL), skipping the version check (offline? ADR-0027)${RESET}"; exit 0; }
  else
    mkdir -p "$cache_root"
    git clone -q --depth 1 "$UPSTREAM_URL" "$GEARBOX_DIR" 2>/dev/null \
      || { echo "${YELLOW}⚠ can't clone upstream ($UPSTREAM_URL), skipping the version check (offline? ADR-0027)${RESET}"; exit 0; }
  fi
else
  echo "${RED}✗ Gearbox upstream not found${RESET}"
  echo "  no local $DEFAULT_LOCAL/docs/gearbox-adr, and no .gearbox-upstream config at the repo root"
  echo "  set the GEARBOX_DIR env var, or put the upstream git URL in .gearbox-upstream (ADR-0027)"
  exit 1
fi
UPSTREAM_ADR_DIR="$GEARBOX_DIR/docs/gearbox-adr"

if [[ ! -d "$UPSTREAM_ADR_DIR" ]]; then
  echo "${RED}✗ Upstream ADR directory missing: $UPSTREAM_ADR_DIR${RESET}"
  exit 1
fi

DOWNSTREAM_ADR_DIR="docs/gearbox-adr"
if [[ ! -d "$DOWNSTREAM_ADR_DIR" ]]; then
  echo "${RED}✗ Current directory has no docs/gearbox-adr/ — run this from a downstream repo's root${RESET}"
  exit 1
fi

REPO_NAME=$(git remote get-url origin 2>/dev/null | sed 's|.*[:/]||; s|\.git$||' || basename "$PWD")
[[ -z "$REPO_NAME" ]] && REPO_NAME=$(basename "$PWD")

# Version summary (ADR-0023): upstream's latest tag vs the local `.gearbox-version` stamp
semver_lag() {
  # $1=local $2=upstream; prints which segment differs. Prints "?" on an invalid format.
  local a=${1#v} b=${2#v}
  if [[ ! "$a" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ || ! "$b" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "?"
    return
  fi
  local a1 a2 a3 b1 b2 b3
  IFS=. read -r a1 a2 a3 <<< "$a"
  IFS=. read -r b1 b2 b3 <<< "$b"
  if [[ "$a1" -ne "$b1" ]]; then echo "major"
  elif [[ "$a2" -ne "$b2" ]]; then echo "minor"
  else echo "patch"; fi
}

# Take the highest version tag (sorted by v:refname — more stable than `describe`, unaffected
# by multiple tags on the same commit). Priority: env override (the npx package passes
# package.json's version, ADR-0028) > remote ls-remote (ADR-0027, a shallow clone isn't
# guaranteed to carry every tag) > local git tag.
if [[ -n "${GEARBOX_UPSTREAM_VERSION:-}" ]]; then
  upstream_version="$GEARBOX_UPSTREAM_VERSION"
elif [[ "$UPSTREAM_IS_REMOTE" -eq 1 ]]; then
  upstream_version=$(git ls-remote --tags --sort=-v:refname "$UPSTREAM_URL" 2>/dev/null \
    | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+$' | head -1 || true)
else
  upstream_version=$(git -C "$GEARBOX_DIR" tag -l 'v*' --sort=-v:refname 2>/dev/null | head -1 || true)
fi
local_version=""
[[ -f .gearbox-version ]] && local_version=$(head -1 .gearbox-version | tr -d '[:space:]')

echo ""
echo "${DIM}repo:${RESET}      $REPO_NAME"
if [[ "$UPSTREAM_IS_REMOTE" -eq 1 ]]; then
  echo "${DIM}upstream:${RESET}  $UPSTREAM_URL ${DIM}(remote cache $GEARBOX_DIR, ADR-0027)${RESET}"
else
  echo "${DIM}upstream:${RESET}  $GEARBOX_DIR"
fi
if [[ -n "$upstream_version" ]]; then
  if [[ -z "$local_version" ]]; then
    echo "${DIM}version:${RESET}   upstream $upstream_version / local ${DIM}no stamp (the next gearbox-update backfill writes it automatically, ADR-0023)${RESET}"
  elif [[ "$local_version" == "$upstream_version" ]]; then
    echo "${DIM}version:${RESET}   ${GREEN}upstream $upstream_version / local $local_version (in sync)${RESET}"
  else
    lag=$(semver_lag "$local_version" "$upstream_version")
    echo "${DIM}version:${RESET}   ${YELLOW}upstream $upstream_version / local $local_version (behind by $lag)${RESET}"
  fi
fi
echo ""

missing_count=0
synced_count=0
drift_count=0
legacy_count=0

for upstream_file in "$UPSTREAM_ADR_DIR"/[0-9][0-9][0-9][0-9]-*.md; do
  base=$(basename "$upstream_file" .md)
  num=${base:0:4}
  slug=${base:5}

  # a) same-slug copy (downstream number can differ)
  copy_match=$(ls "$DOWNSTREAM_ADR_DIR"/[0-9][0-9][0-9][0-9]-"$slug".md 2>/dev/null | head -1 || true)

  # b) provenance reference: literal "scaffold|gearbox ADR-NNNN" text, or a repo URL's adr/NNNN-
  # path. This also matches the English `- Provenance: copied/backfilled from [gearbox ADR-NNNN]`
  # stamp line written by gearbox-install/gearbox-update — the stamp always embeds the literal
  # "gearbox ADR-NNNN" token, so no separate "Provenance:" anchor is needed here; keeping the
  # match broad also still catches a plain prose reference outside the provenance field.
  ref_match=$(grep -lriE "((scaffold|gearbox)[[:space:]]+ADR-${num})|((agents-md-scaffold|gearbox)/blob/[^ )]*adr/${num}-)" \
    "$DOWNSTREAM_ADR_DIR" 2>/dev/null | head -1 || true)

  if [[ -n "$copy_match" ]]; then
    # hash stamp comparison (ADR-0021): the upstream hash recorded in the copy vs the upstream
    # file's current hash
    recorded_hash=$(grep -oE 'sha256:[0-9a-f]{12}' "$copy_match" 2>/dev/null | head -1 | cut -d: -f2 || true)
    if [[ -n "$recorded_hash" ]]; then
      current_hash=$(shasum -a 256 "$upstream_file" | cut -c1-12)
      if [[ "$recorded_hash" == "$current_hash" ]]; then
        echo "  ${GREEN}✅ ADR-${num}${RESET} $slug ${DIM}(copy: $(basename "$copy_match"))${RESET}"
        synced_count=$((synced_count + 1))
      else
        echo "  ${YELLOW}⚠️  ADR-${num}${RESET} $slug ${YELLOW}upstream has been revised${RESET} ${DIM}(copy: $(basename "$copy_match"), manual diff or re-copy)${RESET}"
        drift_count=$((drift_count + 1))
      fi
    else
      echo "  ${GREEN}✅ ADR-${num}${RESET} $slug ${DIM}(copy: $(basename "$copy_match"), no stamp)${RESET}"
      synced_count=$((synced_count + 1))
      legacy_count=$((legacy_count + 1))
    fi
  elif [[ -n "$ref_match" ]]; then
    echo "  ${GREEN}✅ ADR-${num}${RESET} $slug ${DIM}(backfilled: $(basename "$ref_match"))${RESET}"
    synced_count=$((synced_count + 1))
  else
    echo "  ${YELLOW}✖ ADR-${num}${RESET} $slug"
    missing_count=$((missing_count + 1))
  fi
done

echo ""
if [[ "$missing_count" -eq 0 && "$drift_count" -eq 0 ]]; then
  echo "${DIM}status:${RESET}    ${GREEN}✅ fully synced (${synced_count})${RESET}"
else
  echo "${DIM}status:${RESET}    ${YELLOW}⚠️  ${missing_count} not synced, ${drift_count} revised upstream${RESET} ${DIM}(${synced_count} synced)${RESET}"
  echo ""
  echo "${DIM}note: \"not synced\" includes cases the downstream evaluated and declined to backfill${RESET}"
  echo "${DIM}      (this script can't see the issue's conclusion). Authoritative status is upstream${RESET}"
  echo "${DIM}      DOWNSTREAM.md. See Gearbox ADR-0013 (B-3) for the backfill flow.${RESET}"
fi
if [[ "$legacy_count" -gt 0 ]]; then
  echo "${DIM}legacy:    ${legacy_count} copies have no hash stamp, drift can't be detected (ADR-0021; stamps appear naturally on future backfills)${RESET}"
fi
echo ""
