#!/usr/bin/env node
// gearbox-install — one command to scaffold a new project with Gearbox
//
// Usage: run `gearbox-install` from the target project's root, or `gearbox-install <target-dir>`
//   --name <project-name>   AGENTS.md title (default: the target directory's name)
//   --maintainer <name>     replace the <maintainer> placeholder in the protocol (default: keep the placeholder)
//   --gate "<command>"      the Gate command (default: leave a placeholder, generated in sync with CI)
//
// What it does (automates every manual-copy adjustment step from the README, ADR-0022):
//   1. AGENTS.md   copies in the template + transforms: title/intro placeholder, Tech stack placeholder,
//                  removes the dogfood note (keeps the ADR-0018 tier-marking note), <maintainer>
//                  substitution, receiving-end version of the downstream-backfill section, fills in
//                  the Gate command, genericizes Where to find things
//   2. CLAUDE.md   = the `@AGENTS.md` empty-shell contract
//   3. CONTEXT.md  protocol entries copied along (drops the Dogfood row, drops the check-gearbox
//                  hardcoding from the gate row)
//   4. docs/gearbox-adr/   copies every upstream ADR in full, adds a provenance line + hash stamp
//                  to each (ADR-0021 contract)
//   5. ci.yml      generated, command byte-identical to the Gate section (CI == Gate contract)
//   6. .gearbox-version  writes the upstream version tag at onboarding time (ADR-0023 stamp)
//   7. .gearbox-upstream writes the upstream git URL (ADR-0027 remote addressing; lets downstream
//                        gearbox-version/update clone-and-pull when there's no local GEARBOX_DIR)
//
// What it doesn't do:
//   - Doesn't copy pull_request_template.md (the downstream-backfill vehicle, Gearbox-specific), scripts/, README.md
//   - Doesn't overwrite an existing AGENTS.md (onboarded projects use gearbox-update to backfill, not this tool)
//   - Doesn't auto-commit (after install, review by hand + make the first commit)
//
// Every transform anchors to known text in the upstream AGENTS.md; if an anchor isn't found, it errors
// out instead of silently scaffolding something broken.

import {
  readFileSync,
  writeFileSync,
  existsSync,
  readdirSync,
  mkdirSync,
} from "node:fs";
import { createHash } from "node:crypto";
import { execSync } from "node:child_process";
import { join, resolve, basename } from "node:path";
import { env, argv, exit, cwd } from "node:process";

// ============== Config ==============

const GEARBOX_DIR = env.GEARBOX_DIR || `${env.HOME}/Github/gearbox`;
const GEARBOX_ADR_DIR = join(GEARBOX_DIR, "docs/gearbox-adr");
const GEARBOX_GITHUB_BASE =
  "https://github.com/real-stanyan/gearbox/blob/master/docs/gearbox-adr";

const C = {
  red: (s) => `\x1b[31m${s}\x1b[0m`,
  green: (s) => `\x1b[32m${s}\x1b[0m`,
  yellow: (s) => `\x1b[33m${s}\x1b[0m`,
  dim: (s) => `\x1b[2m${s}\x1b[0m`,
  bold: (s) => `\x1b[1m${s}\x1b[0m`,
  cyan: (s) => `\x1b[36m${s}\x1b[0m`,
};

function die(msg, hint = "") {
  console.error(C.red(`✗ ${msg}`));
  if (hint) console.error(`  ${C.dim(hint)}`);
  exit(1);
}

function pad4(n) {
  return String(n).padStart(4, "0");
}

// ============== Args ==============

const args = argv.slice(2);
let targetDir = null;
let projectName = null;
let maintainer = null;
let gateCmd = null;

for (let i = 0; i < args.length; i++) {
  const a = args[i];
  if (a === "--name") projectName = args[++i];
  else if (a === "--maintainer") maintainer = args[++i];
  else if (a === "--gate") gateCmd = args[++i];
  else if (a === "--help" || a === "-h") {
    console.log(
      'gearbox-install [target-dir] [--name project-name] [--maintainer name] [--gate "command"]',
    );
    exit(0);
  } else if (a.startsWith("--")) die(`Unknown argument: ${a}`, "see --help for usage");
  else if (targetDir) die(`Extra positional argument: ${a}`);
  else targetDir = a;
}

targetDir = resolve(targetDir || cwd());
projectName = projectName || basename(targetDir);

// ============== Preflight ==============

if (!existsSync(GEARBOX_ADR_DIR))
  die(
    `Gearbox not found: ${GEARBOX_DIR}`,
    "set the GEARBOX_DIR env var to change the path, or make sure Gearbox is at ~/Github/gearbox/",
  );
if (!existsSync(targetDir)) die(`Target directory does not exist: ${targetDir}`);
if (existsSync(join(targetDir, "AGENTS.md")))
  die(
    `Target already has an AGENTS.md: ${targetDir}`,
    "onboarded projects use gearbox-update to backfill ADRs — don't reinstall with this tool",
  );

const agentsSrc = readFileSync(join(GEARBOX_DIR, "AGENTS.md"), "utf8");
const contextSrc = readFileSync(join(GEARBOX_DIR, "CONTEXT.md"), "utf8");

// Anchor-based transform: the anchor must appear exactly once in the text, otherwise the
// upstream template changed and this tool hasn't caught up → error out.
function mustReplace(content, anchor, replacement, what) {
  const idx = content.indexOf(anchor);
  if (idx === -1)
    die(
      `AGENTS.md template anchor missing: ${what}`,
      "upstream AGENTS.md structure changed — update gearbox-install's transforms before installing (anchor contract, ADR-0022)",
    );
  if (content.indexOf(anchor, idx + 1) !== -1)
    die(`AGENTS.md template anchor not unique: ${what}`);
  return content.replace(anchor, replacement);
}

// ============== 1. AGENTS.md transform ==============

let agents = agentsSrc;

// Title + intro
agents = mustReplace(agents, "# Gearbox\n", `# ${projectName}\n`, "title");
agents = mustReplace(
  agents,
  "A starter scaffold for multi-agent collaboration projects: `AGENTS.md` as the single source of truth + ADRs + a CI hard gate. For anyone who wants multiple AI coding agents (tool-agnostic — Claude Code, Z Code, Cursor, or any agent coding tool) to take turns working in the same repo without stepping on each other.",
  "<One sentence: what this project is, what counts as done, what the scope boundaries are.>",
  "intro paragraph",
);

// Tech stack → placeholder
agents = mustReplace(
  agents,
  `- Node.js (structural self-check script + \`scripts/gearbox-update\` downstream backfill / \`scripts/gearbox-install\` scaffold install / \`scripts/gearbox-prune\` branch hygiene, no runtime dependencies, ADR-0017/0022/0030)
- Bash (\`scripts/gearbox-version\` downstream sync quick-check, zero dependencies, read-only, ADR-0016)
- Plain Markdown documentation (AGENTS.md / CONTEXT.md / ADRs)`,
  "<Project tech stack, one per line. Example: Next.js 15 / TypeScript / Postgres>",
  "Tech stack",
);

// Hard rules: remove the dogfood note, keep the ADR-0018 tier-marking semantics (receiving-end wording)
agents = mustReplace(
  agents,
  `> **Gearbox's own (dogfood) hard rules are not repeated in this section** — the gate assertions are the source of truth (\`scripts/check-gearbox.js\` is the executable source of truth). Any clause in the protocol body marked **Hard rule** (e.g., the "must open an issue, no silent judgment" hard rule in the "Roles of issues & PRs" section, ADR-0003) **counts as part of this section and is protected under L1**: the criterion anchors to the marking itself, not to which section the clause physically lives in (ADR-0018).
> When you copy this Gearbox: delete this note and replace the placeholder with your project's hard rules.`,
  `> Any clause in the protocol body marked **Hard rule** (e.g., the hard rule in the "Roles of issues & PRs" section) **counts as part of this section and is protected under L1**: the criterion anchors to the marking itself, not to which section the clause physically lives in (ADR-0018).`,
  "Hard rules note",
);

// Downstream backfill section → receiving-end version (pull model, ADR-0026)
agents = mustReplace(
  agents,
  "**Downstream backfill** (ADR-0013, pull trigger see ADR-0026): backfill is **pull-primary** — when a downstream project starts a shift, it runs `gearbox-version` to self-check the protocol version, and runs `gearbox-update` if it's behind (the trigger doesn't depend on upstream knowing about downstream, which fits public forks). On the upstream side: every protocol-change PR still declares `Affects downstream` in the PR body (`yes`/`no` + one reason), but this is now **downgraded to informational — it helps gauge blast radius, and no longer opens an issue per downstream project or blocks merge** (\"no link = can't merge\" was retired along with ADR-0026). A maintainer running a private fleet may **optionally** open notification issues against projects registered in `DOWNSTREAM.md`; this is not mandatory.",
  "> This repo is downstream of Gearbox. Backfill follows the pull model (ADR-0026): step 4 of the three start-of-shift steps runs `gearbox-version` to self-check the protocol version, and `gearbox-update` to backfill if it's behind — it doesn't depend on upstream pushing, it proactively aligns with upstream.",
  "downstream backfill section",
);

// Inject a 4th self-check step into the three start-of-shift steps (pull-triggered, ADR-0026) —
// downstream only; upstream Gearbox itself has no upstream to check
agents = mustReplace(
  agents,
  "3. Run the gate command (see below) to confirm the baseline is green — if it's red, fix it first or open an issue; don't start work on a broken baseline",
  `3. Run the gate command (see below) to confirm the baseline is green — if it's red, fix it first or open an issue; don't start work on a broken baseline
4. Run \`npx gearbox-agents version\` to self-check the protocol version — if behind, run \`npx gearbox-agents update\` to backfill (pull-triggered, ADR-0026/0028; this step is the receiving end aligning with upstream, not upstream pushing. If a local Gearbox checkout is installed, you can also run \`gearbox-version\`/\`gearbox-update\` directly)`,
  "start-of-shift self-check step",
);

// Protocol version number section → receiving-end version (downstream doesn't publish protocol
// versions, it only holds the stamp)
agents = mustReplace(
  agents,
  "**Protocol version number** (ADR-0023): a semver variant, baseline `v0.0.0`. Segment criterion — **major** = a cross-tool/cross-repo contract change (hash stamp format, install-anchor structure, file layout, renames) that needs manual intervention for downstream backfill; **minor** = a new mechanism (new ADR / new tool / new protocol clause); **patch** = a revision to an existing file (wording, a status line, a typo). Process (ADR-0029 completes it through npm launch) — the PR body must declare `Version bump: major|minor|patch|none` (`none` needs one reason, enforced via the PR template); **in the same PR, the author sets `package.json`'s `version` to this change's target version (= latest tag + segment, held equal to the git tag, ADR-0028)**; after merge, **the author agent** tags an annotated tag based on the latest tag at merge time and pushes it; **then the maintainer runs `npm publish` to release the npx package (ADR-0028/0029; this hits an external registry and needs credentials, so agents don't run it on the maintainer's behalf)**. A `none` segment triggers no tag/publish and doesn't touch `package.json`'s version. No CHANGELOG is maintained — the tag message + the ADR serve as the change record. Downstream local versions are recorded in the `.gearbox-version` stamp file, written and read by tooling (install writes it at scaffold time / update refreshes it during backfill / version reads it to compare) — humans don't maintain it.",
  "> This repo doesn't publish protocol versions; the root `.gearbox-version` records the upstream Gearbox version at onboarding time, maintained by gearbox-install / gearbox-update, and read/compared by `gearbox-version` (upstream ADR-0023).",
  "protocol version number section",
);

// Gate command + explanation
const gatePlaceholder = "<gate command, e.g.: npx tsc --noEmit && npx vitest run>";
const effectiveGate = gateCmd || gatePlaceholder;
agents = mustReplace(
  agents,
  "```bash\nnode scripts/check-gearbox.js\n```",
  "```bash\n" + effectiveGate + "\n```",
  "Gate command",
);
agents = mustReplace(
  agents,
  `> This repo is a documentation-only template (the Gearbox core itself), so the gate doesn't run vitest/tsc/lint — it runs a **structural self-check script**: it verifies required files exist, \`CLAUDE.md\` is still the \`@AGENTS.md\` empty shell, the key section anchors haven't been renamed, \`HANDOFF\` never appears, and this Gate section actually runs this script (guarding against "CI and AGENTS.md running different things" contract drift).`,
  `> Fill in the gate to match your actual project — any command that can automatically assert "nothing's broken" works (rationale: ADR-0002). See ADR-0020 for how test-type gates (vitest/tsc/lint) map onto the L1/L2 tiers. The command must be byte-identical to \`.github/workflows/ci.yml\` (CI == Gate contract).`,
  "Gate explanation",
);

// Where to find things → genericize
agents = mustReplace(
  agents,
  `- \`CONTEXT.md\` — domain glossary
- \`docs/gearbox-adr/\` — protocol ADRs (copied from Gearbox, managed by tooling — don't hand-edit)
- \`docs/adr/\` — this project's own architectural decisions (starting at 0001)
- \`scripts/\` — gate self-check (check-gearbox.js) + the downstream tool family (gearbox-install scaffold / gearbox-version read / gearbox-update write / gearbox-prune branch hygiene, ADR-0016/0017/0022/0030)
- <other module documentation directories, e.g. docs/modules/>`,
  `- \`CONTEXT.md\` — domain glossary
- \`docs/gearbox-adr/\` — protocol ADRs (copied from Gearbox, managed by tooling — don't hand-edit)
- \`docs/adr/\` — this project's own architectural decisions (starting at 0001, human-authored)
- <other module documentation directories, e.g. docs/modules/>`,
  "Where to find things",
);

// Maintainer-replacement note: the tool already handles this (or leaves the placeholder), so the
// original note is noise downstream → delete
agents = mustReplace(
  agents,
  "\n> **When you copy this Gearbox: replace `<maintainer>` with your (or your team's) name.** See ADR-0006.\n",
  "\n",
  "maintainer note",
);

// Division of labor: strip Gearbox-specific wording
agents = mustReplace(
  agents,
  "Division of labor is a project-level property; the template doesn't presume one (ADR-0008). When you copy this, pick one of three:",
  "Division of labor is a project-level property; the template doesn't presume one (ADR-0008). Pick one of three:",
  "Division of labor intro",
);
agents = mustReplace(
  agents,
  "3. **Single-agent project**: delete this whole section (it's not a gate anchor, so deleting it won't break `check-gearbox.js`).",
  "3. **Single-agent project**: delete this whole section (it's not a gate anchor, so deleting it won't break the gate).",
  "Division of labor item 3",
);

// <maintainer> substitution (optional)
if (maintainer) agents = agents.replaceAll("<maintainer>", maintainer);

// ============== 2. docs/gearbox-adr/ full copy + hash stamp ==============

const adrFiles = readdirSync(GEARBOX_ADR_DIR)
  .filter((f) => /^\d{4}-.+\.md$/.test(f))
  .sort();
if (adrFiles.length === 0) die("Upstream docs/gearbox-adr/ is empty?");

mkdirSync(join(targetDir, "docs/gearbox-adr"), { recursive: true });
let stamped = 0;
for (const f of adrFiles) {
  let content = readFileSync(join(GEARBOX_ADR_DIR, f), "utf8");
  // Provenance line + hash stamp (ADR-0021 contract: first 12 chars of sha256). Skip files that
  // already have a provenance field.
  if (!/- Provenance:/.test(content.split("\n").slice(0, 15).join("\n"))) {
    const hash = createHash("sha256").update(content).digest("hex").slice(0, 12);
    const num = f.slice(0, 4);
    const provenanceLine = `- Provenance: copied from [gearbox ADR-${num}](${GEARBOX_GITHUB_BASE}/${f}) (gearbox-install init, upstream sha256:${hash})`;
    const lines = content.split("\n");
    let insertAt = 1;
    for (let i = 0; i < Math.min(lines.length, 8); i++) {
      if (/^- Date:/.test(lines[i])) {
        insertAt = i + 1;
        break;
      }
    }
    lines.splice(insertAt, 0, provenanceLine);
    content = lines.join("\n");
    stamped++;
  }
  writeFileSync(join(targetDir, "docs/gearbox-adr", f), content);
}

// ============== 3. CONTEXT.md transform ==============

let context = contextSrc;
context = context.replace(
  "# Domain context — Gearbox",
  `# Domain context — ${projectName}`,
);
// Remove the Dogfood row (Gearbox-specific)
context = context
  .split("\n")
  .filter((l) => !/^\| Dogfood \|/.test(l))
  .join("\n");
// Strip the check-gearbox hardcoding from the gate row
context = context.replace(
  "The command that must be all-green before ending a shift. In this repo: `node scripts/check-gearbox.js`",
  "The command that must be all-green before ending a shift. See the Gate section in AGENTS.md for this repo's command",
);

// ============== 4. CLAUDE.md + ci.yml ==============

const claudeMd = "@AGENTS.md\n";

const ciYml = `name: gate

on:
  push:
    branches: [main, master]
  pull_request:

jobs:
  gate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 24
      # IMPORTANT: keep this identical to the Gate section in AGENTS.md.
      # That sameness is the contract that lets CI enforce what agents promise.
      - run: ${gateCmd || "echo '<fill in the Gate command, byte-identical to the Gate section in AGENTS.md>' && exit 1"}
`;

// ============== Write to disk ==============

writeFileSync(join(targetDir, "AGENTS.md"), agents);
writeFileSync(join(targetDir, "CLAUDE.md"), claudeMd);
writeFileSync(join(targetDir, "CONTEXT.md"), context);
mkdirSync(join(targetDir, ".github/workflows"), { recursive: true });
writeFileSync(join(targetDir, ".github/workflows/ci.yml"), ciYml);

// .gearbox-version stamp (ADR-0023): records the upstream version at onboarding time;
// gearbox-version reads and compares against it.
// Priority: env override (npx package passes the package.json version, ADR-0028) > local git tag.
let upstreamVersion = env.GEARBOX_UPSTREAM_VERSION || null;
if (!upstreamVersion) {
  try {
    // Take the highest version tag (semver-sorted; more stable than describe — unaffected by
    // multiple tags on the same commit)
    upstreamVersion =
      execSync("git tag -l 'v*' --sort=-v:refname", {
        cwd: GEARBOX_DIR,
        encoding: "utf8",
        stdio: ["pipe", "pipe", "pipe"],
      })
        .trim()
        .split("\n")[0] || null;
  } catch {
    /* Upstream has no tag (baseline not tagged) → don't write the stamp, warn in the report */
  }
}
if (upstreamVersion)
  writeFileSync(join(targetDir, ".gearbox-version"), upstreamVersion + "\n");

// .gearbox-upstream config (ADR-0027): the upstream git URL, so downstream can do remote
// addressing when there's no local GEARBOX_DIR (pulling from an unfamiliar fork). Prefer the
// origin URL of the upstream clone; in the npx scenario (the package isn't a git repo), fall
// back to reading repository.url from package.json; skip if neither is available.
let upstreamUrl = null;
try {
  upstreamUrl = execSync("git remote get-url origin", {
    cwd: GEARBOX_DIR,
    encoding: "utf8",
    stdio: ["pipe", "pipe", "pipe"],
  }).trim() || null;
} catch {
  /* Upstream clone has no origin remote (e.g. an npx package) → try package.json */
}
if (!upstreamUrl) {
  try {
    const pkg = JSON.parse(readFileSync(join(GEARBOX_DIR, "package.json"), "utf8"));
    upstreamUrl = (pkg.repository && pkg.repository.url) || null;
  } catch {
    /* No package.json / no repository → skip, downstream falls back to GEARBOX_DIR */
  }
}
if (upstreamUrl)
  writeFileSync(join(targetDir, ".gearbox-upstream"), upstreamUrl + "\n");

// git init (when there's no .git)
let gitInited = false;
if (!existsSync(join(targetDir, ".git"))) {
  try {
    execSync("git init -q", { cwd: targetDir });
    gitInited = true;
  } catch {
    /* Don't block install even if git isn't installed */
  }
}

// ============== Report ==============

console.log("");
console.log(C.bold("⟳ gearbox-install"));
console.log(`${C.dim("Project:")}    ${projectName}`);
console.log(`${C.dim("Directory:")}  ${targetDir}`);
console.log(`${C.dim("Upstream:")}   ${GEARBOX_DIR}`);
console.log("");
console.log(`  ${C.green("✓")} AGENTS.md   ${C.dim(`(maintainer: ${maintainer || "<maintainer> placeholder"}; Gate: ${gateCmd || "placeholder"})`)}`);
console.log(`  ${C.green("✓")} CLAUDE.md   ${C.dim("(@AGENTS.md empty-shell contract)")}`);
console.log(`  ${C.green("✓")} CONTEXT.md  ${C.dim("(protocol entries copied along)")}`);
console.log(`  ${C.green("✓")} docs/gearbox-adr/ ${C.dim(`(${adrFiles.length} upstream protocol ADRs, ${stamped} stamped with a hash, ADR-0021)`)}`);
console.log(`  ${C.green("✓")} ci.yml      ${C.dim(gateCmd ? "(same command as the Gate section)" : "(placeholder command, deliberately red — CI shouldn't be green before Gate is filled in)")}`);
if (upstreamVersion)
  console.log(`  ${C.green("✓")} .gearbox-version ${C.dim(`(${upstreamVersion}, ADR-0023 version stamp)`)}`);
else
  console.log(`  ${C.yellow("⚠")} .gearbox-version ${C.dim("not written — upstream has no tag (baseline v0.0.0 not tagged?)")}`);
if (upstreamUrl)
  console.log(`  ${C.green("✓")} .gearbox-upstream ${C.dim(`(${upstreamUrl}, ADR-0027 remote addressing)`)}`);
if (gitInited) console.log(`  ${C.green("✓")} git init`);
console.log("");
console.log(C.bold("Next steps:"));
let step = 1;
const placeholderHint =
  "(intro / Hard rules / Tech stack" +
  (maintainer ? "" : " / <maintainer>") +
  (gateCmd ? ")" : " / Gate command, sync ci.yml)");
console.log(`  ${step++}. Fill in placeholders: ${C.cyan("grep -n '<' AGENTS.md")} ${C.dim(placeholderHint)}`);
console.log(`  ${step++}. Write your first own decision to ${C.cyan(`docs/adr/0001-*.md`)} ${C.dim("(project ADRs number independently; protocol ADRs live in docs/gearbox-adr/, format in 0001-adr-template.md)")}`);
console.log(`  ${step++}. First commit + push, then step 4 of the three start-of-shift steps runs ${C.cyan("gearbox-version")} to self-check the protocol version (pull-triggered, ADR-0026)`);
console.log(`  ${C.dim(`  (optional) the maintainer can add this project to ~/Github/gearbox/DOWNSTREAM.md's fleet dashboard — not required, backfill relies on downstream self-check, not the list`)}`);
console.log("");
