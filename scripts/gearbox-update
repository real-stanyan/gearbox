};

function generateReport({
  downstreamRepo,
  assignments,
  refreshes,
  supersedeResult,
  branchName,
  reportDate,
  baseBranch,
}) {
  const lines = [];
  lines.push(`# gearbox-update report`);
  lines.push("");
  lines.push(`- Date: ${reportDate}`);
  lines.push(`- Downstream: ${downstreamRepo}`);
  lines.push(`- Branch: \`${branchName}\``);
  lines.push("");

  if (assignments.length === 0 && refreshes.length === 0) {
    lines.push("## No ADRs to backfill ✅");
    lines.push("");
    lines.push("Downstream is already synced to the latest gearbox.");
    return lines.join("\n");
  }

  // Drift re-copy table (ADR-0024)
  if (refreshes.length > 0) {
    lines.push("## ADRs re-copied due to drift (--refresh-drift)");
    lines.push("");
    lines.push(
      "Files where upstream was revised and the downstream copy was **overwritten**. ⚠️ If downstream had made local edits to these copies, they're gone — pay special attention to these when reviewing the diff:",
    );
    lines.push("");
    lines.push("| gearbox | slug |");
    lines.push("|---|---|");
    for (const a of refreshes) {
      lines.push(`| ADR-${pad4(a.gearbox.num)} | ${a.gearbox.slug} |`);
    }
    lines.push("");
  }

  // Backfilled table (number is 1:1 with upstream, no renumbering)
  if (assignments.length > 0) {
    lines.push("## Backfilled ADRs");
    lines.push("");
    lines.push("| gearbox | slug |");
    lines.push("|---|---|");
    for (const action of assignments) {
      lines.push(`| ADR-${pad4(action.gearbox.num)} | ${action.gearbox.slug} |`);
    }
    lines.push("");
  }

  // supersede link
  if (supersedeResult) {
    lines.push("## Supersede link (gearbox 0012 → downstream 0006)");
    lines.push("");
    if (supersedeResult.alreadyApplied) {
      lines.push(
        `- Downstream 0006's status is already partially superseded (idempotent, not re-applied)`,
      );
    } else {
      lines.push(
        `- Downstream \`docs/gearbox-adr/0006-tiered-change-authority.md\`'s status changed to \`partially superseded by ADR-${pad4(supersedeResult.newNum)}\``,
      );
    }
    lines.push("");
  }

  // AGENTS.md hand-edits needed
  const agentsMdTasks = assignments
    .map((action) => ({
      adr: action.gearbox,
      impact: AGENTS_MD_IMPACT[action.gearbox.num],
    }))
    .filter((t) => t.impact);

  if (agentsMdTasks.length > 0) {
    lines.push("## ⚠️ AGENTS.md needs a hand-edit (the script doesn't touch AGENTS.md, an L1 file)");
    lines.push("");
    lines.push(
      "The script is a tool, not a protocol enforcer — AGENTS.md's L1 changes need your review before you add them by hand. Suggestion: grep-check whether the corresponding subsection already exists for each change (an idempotent backfill run may have already added it).",
    );
    lines.push("");
    for (const t of agentsMdTasks) {
      lines.push(
        `### ADR-${pad4(t.adr.num)} (${t.adr.slug}) → edit \`${t.impact.section}\``,
      );
      lines.push("");
      lines.push(`${t.impact.note}`);
      lines.push("");
      lines.push(
        `Reference: [gearbox AGENTS.md](https://github.com/real-stanyan/gearbox/blob/master/AGENTS.md)`,
      );
      lines.push("");
    }
  }

  // commit + push status
  lines.push("## Committed + pushed");
  lines.push("");
  lines.push(`- Branch pushed to remote: \`origin/${branchName}\``);
  lines.push("- The script did **not** open a PR (L1 changes need maintainer agreement)");
  lines.push("");
  lines.push("### Next steps (manual)");
  lines.push("");
  lines.push("```bash");
  lines.push(
    `gh pr create --base ${baseBranch} --head ${branchName} \\`,
  );
  const titleParts = [
    ...assignments.map((action) => pad4(action.gearbox.num)),
    ...refreshes.map((a) => `${pad4(a.gearbox.num)}(refresh)`),
  ];
  lines.push(`  --title "docs(adr): backfill gearbox ADR ${titleParts.join(" + ")}" \\`);
  lines.push(`  --body "..."`);
  lines.push("```");
  lines.push("");
  lines.push("- [ ] review the diff");
  lines.push("- [ ] hand-edit AGENTS.md per the sections above (L1)");
  lines.push("- [ ] run the downstream gate");
  lines.push("- [ ] open the PR, wait for the maintainer to write \"agree\" in a PR comment before merging (L1 b-weak form)");
  lines.push("");
  lines.push("## Cleanup once done");
  lines.push("");
  lines.push("- [ ] delete this report file `gearbox-update-report.md` after the PR merges");
  lines.push("");

  return lines.join("\n");
}

// ============== git operations ==============

function gitOps(downDir, assignments, refreshes, supersedeResult, branchName, upstreamVersion) {
  // Create the branch
  run(`git checkout -b ${branchName}`);

  // One commit per drift re-copy (ADR-0024)
  for (const a of refreshes) {
    const dstPath = `docs/gearbox-adr/${pad4(a.gearbox.num)}-${a.gearbox.slug}.md`;
    run(`git add ${dstPath}`);
    const gearboxUrl = `${GEARBOX_GITHUB_BASE}/${pad4(a.gearbox.num)}-${a.gearbox.slug}.md`;
    const commitMsg = `docs(adr): drift re-copy ADR-${pad4(a.gearbox.num)} (${a.gearbox.slug})

Upstream gearbox ADR-${pad4(a.gearbox.num)} has been revised (hash drift); rerunning the
transform against upstream's latest content and overwriting, provenance stamp refreshed →
sha256:${sha12(a.gearbox.content)}.
by gearbox-update --refresh-drift (gearbox ADR-0024).
Provenance: ${gearboxUrl}`;
    runWithStdin(`git commit -F -`, commitMsg);
  }

  // One commit per backfilled ADR (number is 1:1 with upstream, no renumbering)
  for (const action of assignments) {
    const gearboxAdr = action.gearbox;
    const dstPath = `docs/gearbox-adr/${pad4(gearboxAdr.num)}-${gearboxAdr.slug}.md`;
    run(`git add ${dstPath}`);

    const gearboxUrl = `${GEARBOX_GITHUB_BASE}/${pad4(gearboxAdr.num)}-${gearboxAdr.slug}.md`;
    const commitMsg = `docs(adr): backfill gearbox ADR-${pad4(gearboxAdr.num)} (${gearboxAdr.slug})

by gearbox-update tool.
Provenance: ${gearboxUrl}

Note: the corresponding AGENTS.md section needs a manual edit (an L1 file, the script doesn't
    touch it). See gearbox-update-report.md.`;

    runWithStdin(`git commit -F -`, commitMsg);
  }

  // supersede-link commit (if it changed)
  if (supersedeResult && !supersedeResult.alreadyApplied) {
    run(`git add docs/gearbox-adr/0006-tiered-change-authority.md`);
    const commitMsg = `docs(adr): sync 0006 status → partially superseded by ADR-${pad4(supersedeResult.newNum)}

gearbox 0012 supersedes 0006; this commit syncs downstream 0006's status line to
partially superseded. by gearbox-update tool.`;
    runWithStdin(`git commit -F -`, commitMsg);
  }

  // .gearbox-version stamp (ADR-0023): a completed backfill counts as synced to upstream's
  // current version. Skip if unchanged — an empty commit would fail.
  let stampUpdated = false;
  if (upstreamVersion) {
    const stampPath = join(downDir, ".gearbox-version");
    const prev = existsSync(stampPath)
      ? readFileSync(stampPath, "utf8").trim()
      : null;
    if (prev !== upstreamVersion) {
      writeFileSync(stampPath, upstreamVersion + "\n");
      run("git add .gearbox-version");
      const commitMsg = `chore: .gearbox-version → ${upstreamVersion}

Backfill complete, version stamp updated to upstream's latest tag (gearbox ADR-0023).
by gearbox-update tool.`;
      runWithStdin(`git commit -F -`, commitMsg);
      stampUpdated = true;
    }
  }

  // push (--force-redo rebuilt the branch → --force-with-lease to overwrite the remote, ADR-0025)
  const pushResult = tryRun(
    forceRedo
      ? `git push --force-with-lease -u origin ${branchName} 2>&1`
      : `git push -u origin ${branchName} 2>&1`,
  );
  return { pushResult, stampUpdated };
}

// ============== main flow ==============

async function main() {
  await tui.logo();
  if (!tui.isTTY) stdout.write(C.bold(C.cyan("\n⟳ gearbox-update\n")));
  stdout.write(C.dim("  aggressive downstream ADR sync tool\n\n"));

  resolveUpstream(); // upstream addressing (local/remote), overwrites GEARBOX_DIR (ADR-0027)
  const { downDir, downAdrDir, branch } = validateContext();
  // PR base uses the detected main branch; if running on some other branch, falls back to master
  const baseBranch = branch === "main" || branch === "master" ? branch : "master";

  // repo name
  const remoteUrl = tryRun("git remote get-url origin") || "";
  const downRepo =
    remoteUrl.replace(/.*[:/]/, "").replace(/\.git$/, "") ||
    downDir.split("/").pop();

  stdout.write(`${C.dim("downstream:")}  ${downRepo}\n`);
  stdout.write(
    UPSTREAM_URL
      ? `${C.dim("gearbox:")}     ${UPSTREAM_URL} ${C.dim(`(remote cache ${GEARBOX_DIR}, ADR-0027)`)}\n\n`
      : `${C.dim("gearbox:")}     ${GEARBOX_DIR}\n\n`,
  );

  // scan both sides
  const gearboxIndex = buildAdrIndex(GEARBOX_ADR_DIR);
  const downIndex = buildAdrIndex(downAdrDir);

  if (gearboxIndex.size === 0) {
    die("gearbox ADR directory is empty", `check ${GEARBOX_ADR_DIR}`);
  }

  stdout.write(
    `${C.dim("gearbox ADRs:")}    ${pad4(Math.max(...gearboxIndex.keys()))} (${gearboxIndex.size} total)\n`,
  );
  stdout.write(
    `${C.dim("downstream ADRs:")} ${pad4(Math.max(...downIndex.keys()))} (${downIndex.size} total)\n\n`,
  );

  // match
  const actions = matchAdrs(gearboxIndex, downIndex, refreshDrift);

  // print diagnostics (sorted ascending by gearbox num, to keep output/commit order stable)
  const skipped = actions.filter((a) => a.type === "skip");
  const toCopy = actions
    .filter((a) => a.type === "copy")
    .sort((a, b) => a.gearbox.num - b.gearbox.num);
  const toRefresh = actions.filter((a) => a.type === "refresh");
  const driftedSkips = skipped.filter((a) => a.drifted);

  if (toCopy.length === 0 && toRefresh.length === 0) {
    stdout.write(C.green("✅ No ADRs to backfill — downstream is already synced to the latest gearbox\n\n"));
    // TTY: one summary line — the per-ADR skip wall adds nothing when everything is synced.
    // Non-TTY (CI, pipes): full listing, unchanged.
    if (tui.isTTY) {
      stdout.write(C.dim(`Already skipped: ${skipped.length} ADRs the downstream already has\n`));
    } else {
      stdout.write(C.dim("Already skipped (downstream already has these):\n"));
      for (const a of skipped) {
        stdout.write(
          `  ${C.dim("skip")} ADR-${pad4(a.gearbox.num)} ${a.gearbox.slug} — ${a.reason}\n`,
        );
      }
    }
    if (driftedSkips.length > 0) {
      stdout.write(
        C.yellow(
          `\n⚠️  ${driftedSkips.length} copies have been revised upstream (hash drift) — re-copy with gearbox-update --refresh-drift (ADR-0024)\n`,
        ),
      );
    }
    stdout.write("\n");
    return;
  }

  if (toCopy.length > 0) {
    stdout.write(C.yellow(`⚠️  ${toCopy.length} to backfill:\n`));
    for (const a of toCopy) {
      stdout.write(
        `  ${C.green("[original-number copy]")} gearbox ADR-${pad4(a.gearbox.num)} ${a.gearbox.slug} — ${a.reason}\n`,
      );
    }
  }
  if (toRefresh.length > 0) {
    stdout.write(C.yellow(`⚠️  ${toRefresh.length} to re-copy (drift):\n`));
    for (const a of toRefresh) {
      stdout.write(
        `  ${C.yellow("[drift re-copy]")} gearbox ADR-${pad4(a.gearbox.num)} ${a.gearbox.slug} — ${a.reason}\n`,
      );
    }
  }
  // TTY: one summary line (see the no-backfill branch above); non-TTY: full listing.
  if (tui.isTTY) {
    stdout.write(`\n${C.dim(`Already skipped: ${skipped.length} ADRs the downstream already has`)}\n`);
  } else {
    stdout.write(`\n${C.dim("Already skipped (downstream already has these):")}\n`);
    for (const a of skipped) {
      stdout.write(
        `  ${C.dim("skip")} ADR-${pad4(a.gearbox.num)} ${a.gearbox.slug} — ${a.reason}\n`,
      );
    }
  }
  if (driftedSkips.length > 0 && !refreshDrift) {
    stdout.write(
      C.yellow(
        `  ⚠️  ${driftedSkips.length} of these have drifted — re-copy with gearbox-update --refresh-drift (ADR-0024)\n`,
      ),
    );
  }
  stdout.write("\n");

  // copy (number is 1:1 with upstream, no more assignment/renumbering)
  if (toCopy.length > 0) {
    stdout.write(C.bold("Copying:\n"));
    if (tui.isTTY) {
      await tui.progress(
        "backfill",
        toCopy.map((a) => `${pad4(a.gearbox.num)}-${a.gearbox.slug}.md`),
        (name, i) => {
          const gearboxAdr = toCopy[i].gearbox;
          const dstPath = join(downAdrDir, `${pad4(gearboxAdr.num)}-${gearboxAdr.slug}.md`);
          writeFileSync(dstPath, transformAdrContent(gearboxAdr));
        },
        { perItemMs: 60, doneNote: `(${toCopy.length} ADRs copied under their upstream numbers)` },
      );
    } else {
      for (const action of toCopy) {
        const gearboxAdr = action.gearbox;
        const dstPath = join(downAdrDir, `${pad4(gearboxAdr.num)}-${gearboxAdr.slug}.md`);
        const transformed = transformAdrContent(gearboxAdr);
        writeFileSync(dstPath, transformed);
        stdout.write(
          `  ${C.green("✓")} ${dstPath.replace(downDir + "/", "")}\n`,
        );
      }
    }
    stdout.write("\n");
  }

  // execute drift re-copies (ADR-0024): keep the downstream number (= upstream original
  // number), rerun the transform against upstream's latest content and overwrite
  if (toRefresh.length > 0) {
    stdout.write(C.bold("Drift re-copy (overwrite, stamp refreshed):\n"));
    for (const a of toRefresh) {
      const dstPath = join(
        downAdrDir,
        `${pad4(a.gearbox.num)}-${a.gearbox.slug}.md`,
      );
      const transformed = transformAdrContent(a.gearbox);
      writeFileSync(dstPath, transformed);
      stdout.write(
        `  ${C.green("✓")} ${dstPath.replace(downDir + "/", "")} ${C.dim(`(upstream sha256:${sha12(a.gearbox.content)})`)}\n`,
      );
    }
    stdout.write("\n");
  }

  // supersede link (only triggers when this run actually backfilled gearbox 0012)
  let supersedeResult = null;
  if (toCopy.some((a) => a.gearbox.num === 12)) {
    stdout.write(C.bold("Supersede link (gearbox 0012 → downstream 0006):\n"));
    supersedeResult = applySupersedeLink(downAdrDir);
    if (supersedeResult) {
      if (supersedeResult.alreadyApplied) {
        stdout.write(
          `  ${C.dim("✓ 0006 status is already partially superseded, idempotent, unchanged")}\n`,
        );
      } else {
        stdout.write(
          `  ${C.green("✓")} 0006 status → partially superseded by ADR-${pad4(supersedeResult.newNum)}\n`,
        );
      }
    } else {
      stdout.write(
        `  ${C.dim("Downstream has no 0006-tiered-change-authority.md, skipping")}\n`,
      );
    }
    stdout.write("\n");
  }

  // git operations
  const reportDate = new Date().toISOString().slice(0, 10);
  const branchName = `docs/gearbox-backfill-${reportDate}`;

  // Upstream's highest version tag (for the ADR-0023 stamp; semver-sorted, skip the stamp if
  // there's no tag). Priority: env override (npx package passes package.json version,
  // ADR-0028) > remote ls-remote (ADR-0027, a shallow clone isn't guaranteed to carry every
  // tag) > local git tag.
  const upstreamVersion =
    env.GEARBOX_UPSTREAM_VERSION ||
    (UPSTREAM_URL
      ? ((tryRun(`git ls-remote --tags --sort=-v:refname "${UPSTREAM_URL}"`) || "")
          .split("\n")
          .map((l) => (l.match(/v[0-9]+\.[0-9]+\.[0-9]+$/) || [])[0])
          .filter(Boolean)[0] || null)
      : ((tryRun(`git -C "${GEARBOX_DIR}" tag -l 'v*' --sort=-v:refname`) || "")
          .split("\n")[0] || null));

  stdout.write(C.bold(`git operations (branch ${branchName}):\n`));
  try {
    const { pushResult, stampUpdated } = gitOps(
      downDir,
      toCopy,
      toRefresh,
      supersedeResult,
      branchName,
      upstreamVersion,
    );
    for (const a of toRefresh) {
      stdout.write(
        `  ${C.green("✓ commit")} drift re-copy ADR-${pad4(a.gearbox.num)} (${a.gearbox.slug})\n`,
      );
    }
    for (const action of toCopy) {
      stdout.write(
        `  ${C.green("✓ commit")} ADR-${pad4(action.gearbox.num)}\n`,
      );
    }
    if (supersedeResult && !supersedeResult.alreadyApplied) {
      stdout.write(`  ${C.green("✓ commit")} 0006 status sync\n`);
    }
    if (stampUpdated) {
      stdout.write(
        `  ${C.green("✓ commit")} .gearbox-version → ${upstreamVersion} ${C.dim("(ADR-0023 stamp)")}\n`,
      );
    } else if (upstreamVersion) {
      stdout.write(
        `  ${C.dim(`✓ .gearbox-version is already ${upstreamVersion}, unchanged`)}\n`,
      );
    } else {
      stdout.write(
        `  ${C.yellow("⚠")} .gearbox-version not updated — upstream has no tag\n`,
      );
    }
    if (pushResult) {
      stdout.write(`  ${C.green("✓ push")} origin/${branchName}\n`);
    } else {
      stdout.write(
        `  ${C.yellow("⚠ push failed — local branch already created, push manually:")}\n`,
      );
      stdout.write(`     git push -u origin ${branchName}\n`);
    }
  } catch (e) {
    die(
      `git operation failed: ${e.message}`,
      "local files were written but not committed/pushed, handle it manually:\n  git status\n  git add docs/gearbox-adr/\n  git commit\n  git push",
    );
  }
  stdout.write("\n");

  // generate the report
  const report = generateReport({
    downstreamRepo: downRepo,
    assignments: toCopy,
    refreshes: toRefresh,
    supersedeResult,
    branchName,
    reportDate,
    baseBranch,
  });
  const reportPath = join(downDir, "gearbox-update-report.md");
  writeFileSync(reportPath, report);

  stdout.write(C.green(`✓ report: ${reportPath.replace(downDir + "/", "")}\n`));
  stdout.write(
    C.dim(
      "  (this file isn't committed — delete it by hand after the PR merges)\n\n",
    ),
  );

  stdout.write(tui.isTTY ? "  " + tui.grad("⚙ downstream in sync") + "\n" : C.bold(C.green("✓ done\n")));
  stdout.write("\n");
  stdout.write(C.bold("Next steps:\n"));
  stdout.write(
    `  1. Check ${C.cyan("gearbox-update-report.md")} to decide which AGENTS.md sections need hand-edits\n`,
  );
  stdout.write(`  2. Hand-edit AGENTS.md (L1)\n`);
  stdout.write(`  3. Run the downstream gate\n`);
  stdout.write(`  4. Open a PR:\n`);
  stdout.write(`     ${C.cyan(`gh pr create --base ${baseBranch} --head ${branchName} --title "..." --body "..."`)}\n`);
  stdout.write(
    `  5. Wait for the maintainer to write "agree" in a PR comment before merging (L1 b-weak form)\n\n`,
  );
}

await main();
