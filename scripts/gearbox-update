#!/usr/bin/env node
// gearbox-update — aggressive downstream ADR sync tool
//
// Usage: run `gearbox-update [--refresh-drift] [--force-redo] [--allow-branch]` from a
//   downstream repo's root
//   --refresh-drift  re-copy backfilled ADRs whose "upstream has been revised" (ADR-0024):
//                    for a slug-matched copy carrying a sha256 stamp, when the recorded hash
//                    ≠ the upstream file's current hash, rerun the transform against the
//                    upstream's latest content and overwrite (keeps the downstream number,
//                    stamp gets refreshed). This drops any local edits the downstream made to
//                    the copy — a branch + PR review is the safety net, so it's opt-in.
//   --force-redo     if today's backfill branch already exists, delete and rebuild it
//                    (ADR-0025); push uses --force-with-lease to overwrite the remote. Manual
//                    edits on that branch are lost — confirm there are none before using this.
//                    Default (no flag): error out, don't delete.
//   --allow-branch   skip the "auto-switch back to main/master" step (ADR-0025) and run
//                    against the current branch. Base-branch correctness is on you — if the
//                    base is wrong, the output isn't trustworthy.
//
// Startup safety checks (ADR-0025): the clean-worktree check exempts this tool's own
// gearbox-update-report.md; auto `git checkout main` when not on main/master (unless
// --allow-branch).
//
// What it does:
//   1. Scans for ADRs Gearbox has that downstream lacks, and copies them into
//      docs/gearbox-adr/ under their upstream number (after the dual-directory split,
//      protocol ADR numbers are 1:1 with upstream — no collisions, no renumbering, ADR-0031)
//   2. Syncs supersede relationships (gearbox 0012 → downstream 0006 status becomes
//      partially superseded)
//   3. Updates the `.gearbox-version` stamp to upstream's latest tag (ADR-0023)
//   4. git add + commit + push to a new branch docs/gearbox-backfill-{date}
//   5. Writes gearbox-update-report.md prompting the user to hand-edit AGENTS.md (the script
//      never touches AGENTS.md)
//
// What it doesn't do:
//   - Doesn't touch downstream AGENTS.md (an L1 file — report only)
//   - Doesn't touch any file in the gearbox repo itself (this is a downstream-side tool)
//   - Doesn't run `gh pr create` automatically (left for the user)
//   - Doesn't auto-merge (L1 requires maintainer agreement)
//
// Protocol compliance: this is a personal tool, not a Gearbox protocol change. A backfill PR
// still goes through the downstream's own L1 flow.
// Compared to gearbox-version: version is read-only and reports status; update writes files
// and opens a branch.
//
// Upstream addressing (ADR-0027): env GEARBOX_DIR > local ~/Github/gearbox > .gearbox-upstream
// remote cache (~/.cache/gearbox/, shallow clone). If the remote can't be reached → hard error
// (a failed pull can't be reported as success).

import { readFileSync, writeFileSync, existsSync, readdirSync, statSync, mkdirSync } from "node:fs";
import { createHash } from "node:crypto";
import { execSync } from "node:child_process";
import { join } from "node:path";
import { env, argv, exit, cwd, stdout, stderr } from "node:process";
import * as tui from "./lib/tui.js";

// ============== Config ==============

// Upstream addressing (ADR-0027): resolved at runtime by resolveUpstream() — a hit on
// env/local default uses local, otherwise falls back to the .gearbox-upstream remote
// shallow-clone cache. These three are overwritten by resolveUpstream() at the start of main().
let GEARBOX_DIR = env.GEARBOX_DIR || `${env.HOME}/Github/gearbox`;
let GEARBOX_ADR_DIR = join(GEARBOX_DIR, "docs/gearbox-adr");
let UPSTREAM_URL = null; // = the .gearbox-upstream URL when remote; null when local
const GEARBOX_GITHUB_BASE =
  "https://github.com/real-stanyan/gearbox/blob/master/docs/gearbox-adr";

// CLI args
let refreshDrift = false;
let forceRedo = false;
let allowBranch = false;
for (const a of argv.slice(2)) {
  if (a === "--refresh-drift") refreshDrift = true;
  else if (a === "--force-redo") forceRedo = true;
  else if (a === "--allow-branch") allowBranch = true;
  else if (a === "--help" || a === "-h") {
    console.log(
      "gearbox-update [--refresh-drift] [--force-redo] [--allow-branch]",
    );
    exit(0);
  } else {
    console.error(`Unknown argument: ${a} (see --help for usage)`);
    exit(1);
  }
}

// Colors
const C = {
  red: (s) => `\x1b[31m${s}\x1b[0m`,
  green: (s) => `\x1b[32m${s}\x1b[0m`,
  yellow: (s) => `\x1b[33m${s}\x1b[0m`,
  dim: (s) => `\x1b[2m${s}\x1b[0m`,
  bold: (s) => `\x1b[1m${s}\x1b[0m`,
  cyan: (s) => `\x1b[36m${s}\x1b[0m`,
};

// ============== helpers ==============

function die(msg, hint = "") {
  tui.fail(msg, hint);
  exit(1);
}

function pad4(n) {
  return String(n).padStart(4, "0");
}

// sha256, first 12 chars (ADR-0021 stamp contract)
function sha12(s) {
  return createHash("sha256").update(s).digest("hex").slice(0, 12);
}

function run(cmd, opts = {}) {
  return execSync(cmd, { encoding: "utf8", stdio: ["pipe", "pipe", "pipe"], ...opts }).trim();
}

function tryRun(cmd) {
  try {
    return run(cmd);
  } catch {
    return null;
  }
}

// Upstream addressing (ADR-0027): env > local default > .gearbox-upstream remote cache.
// Overwrites the module-level GEARBOX_DIR / GEARBOX_ADR_DIR / UPSTREAM_URL. Called at the
// start of main().
function resolveUpstream() {
  const localDir = env.GEARBOX_DIR || `${env.HOME}/Github/gearbox`;
  if (existsSync(join(localDir, "docs/gearbox-adr"))) {
    GEARBOX_DIR = localDir; // local hit (a maintainer's own fleet) — don't touch the remote
    GEARBOX_ADR_DIR = join(GEARBOX_DIR, "docs/gearbox-adr");
    return;
  }
  const cfgPath = join(cwd(), ".gearbox-upstream");
  if (existsSync(cfgPath)) {
    const url = (readFileSync(cfgPath, "utf8").split("\n")[0] || "").trim();
    if (url) {
      const cacheRoot = join(env.XDG_CACHE_HOME || `${env.HOME}/.cache`, "gearbox");
      const cacheDir = join(cacheRoot, sha12(url));
      try {
        if (existsSync(join(cacheDir, ".git"))) {
          run(`git -C "${cacheDir}" fetch -q --depth 1 origin`);
          run(`git -C "${cacheDir}" reset -q --hard FETCH_HEAD`);
        } else {
          mkdirSync(cacheRoot, { recursive: true });
          run(`git clone -q --depth 1 "${url}" "${cacheDir}"`);
        }
      } catch {
        // update actively pulls — if it can't reach upstream, that's a hard error (ADR-0027)
        die(
          `Can't reach the upstream remote (offline?): ${url}`,
          "gearbox-update needs to fetch upstream — check your network or the .gearbox-upstream URL (ADR-0027)",
        );
      }
      GEARBOX_DIR = cacheDir;
      GEARBOX_ADR_DIR = join(cacheDir, "docs/gearbox-adr");
      UPSTREAM_URL = url;
      return;
    }
  }
  // Neither is set: keep the local default, existsSync(GEARBOX_ADR_DIR) reports the error later
  GEARBOX_DIR = localDir;
  GEARBOX_ADR_DIR = join(localDir, "docs/gearbox-adr");
}

// Run a git command feeding stdin (used for multi-line commit messages)
function runWithStdin(cmd, input) {
  return execSync(cmd, {
    input,
    encoding: "utf8",
    stdio: ["pipe", "pipe", "pipe"],
  }).trim();
}

// Extract ADR metadata from the filename + content
function parseAdrFile(filePath) {
  const fileName = filePath.split("/").pop();
  const match = fileName.match(/^(\d{4})-(.+)\.md$/);
  if (!match) return null;
  const num = parseInt(match[1], 10);
  const slug = match[2];

  let content = "";
  try {
    content = readFileSync(filePath, "utf8");
  } catch {
    return null;
  }

  const lines = content.split("\n");
  const titleLine = lines.find((l) => l.startsWith("# ADR-"));
  const title = titleLine ? titleLine.replace(/^# ADR-\d+:\s*/, "") : slug;

  // header = the first 15 lines (enough to cover Status/Date/Provenance/Supersedes/Revises)
  const headerLines = lines.slice(0, 15);
  const headerText = headerLines.join("\n");

  // Parse header fields
  const statusMatch = headerText.match(/^- Status:\s*(.+)$/m);
  const supersedesMatch = headerText.match(/^- Supersedes:\s*ADR-(\d+)/m);
  const supersededByMatch = headerText.match(
    /partially superseded by ADR-(\d+)/,
  );
  // Canonical provenance regex: matches both the install-written "copied from" stamp and the
  // update-written "backfilled from" stamp (Gearbox Task 3/4 provenance contract).
  const provenanceMatch = headerText.match(
    /Provenance:\s*(?:copied|backfilled) from\s*\[?(?:scaffold|gearbox)\s+ADR-(\d+)/i,
  );
  const revisesMatch = headerText.match(/Revises:\s*ADR-(\d+)/);

  return {
    num,
    slug,
    title,
    filePath,
    fileName,
    content,
    status: statusMatch ? statusMatch[1].trim() : null,
    supersedes: supersedesMatch ? parseInt(supersedesMatch[1], 10) : null,
    supersededBy: supersededByMatch
      ? parseInt(supersededByMatch[1], 10)
      : null,
    provenanceGearboxNum: provenanceMatch
      ? parseInt(provenanceMatch[1], 10)
      : null,
    revises: revisesMatch ? parseInt(revisesMatch[1], 10) : null,
    hasProvenanceField: /- Provenance:/.test(headerText),
  };
}

function buildAdrIndex(adrDir) {
  const index = new Map(); // num → adr
  if (!existsSync(adrDir)) return index;
  const files = readdirSync(adrDir).filter((f) => /^\d{4}-.*\.md$/.test(f));
  for (const f of files) {
    const adr = parseAdrFile(join(adrDir, f));
    if (adr) index.set(adr.num, adr);
  }
  return index;
}

// ============== entry validation ==============

function validateContext() {
  const downDir = cwd();
  const downAdrDir = join(downDir, "docs/gearbox-adr");

  if (!existsSync(GEARBOX_ADR_DIR)) {
    die(
      `Gearbox ADR directory not found: ${GEARBOX_ADR_DIR}`,
      "set the GEARBOX_DIR env var, or put the upstream git URL in .gearbox-upstream (ADR-0027 remote addressing)",
    );
  }
  if (!existsSync(downAdrDir)) {
    die(
      "Current directory has no docs/gearbox-adr/",
      "run this from a downstream repo's root (Gearbox-protocol projects all have docs/gearbox-adr/)",
    );
  }

  // git repo check
  const inGitRepo = tryRun("git rev-parse --is-inside-work-tree");
  if (inGitRepo !== "true") {
    die("Current directory is not a git repo", "gearbox-update needs git operations");
  }

  // Clean-worktree check (ADR-0025: exempts this tool's own report file — it's disposable and
  // overwritten every run). Only tracked changes (modified/staged/deleted) block: this tool
  // commits file-by-file (git add <path>, never add -A), so untracked files can't be clobbered
  // or swept into a backfill commit — they're listed as an FYI and the run proceeds (#92).
  const statusLines = run("git status --porcelain")
    .split("\n")
    .filter(Boolean)
    .filter((l) => !/gearbox-update-report\.md$/.test(l));
  const trackedDirty = statusLines.filter((l) => !l.startsWith("??"));
  const untracked = statusLines.filter((l) => l.startsWith("??"));
  if (trackedDirty.length > 0) {
    die(
      "Working tree isn't clean, there are uncommitted changes:",
      "commit or stash first, then run gearbox-update (this keeps the script from clobbering your changes):\n" +
        trackedDirty.join("\n"),
    );
  }
  if (untracked.length > 0) {
    stdout.write(
      C.dim(`  ${untracked.length} untracked file(s) present — ignored, backfill commits add files one by one:\n`) +
        C.dim(untracked.map((l) => `  ${l}`).join("\n") + "\n"),
    );
  }

  // Base branch (ADR-0025): auto-switch when not on main/master, so the backfill branch
  // doesn't fork from the wrong base (inheriting stale copies, producing untrustworthy
  // output). --allow-branch skips this — base-branch correctness is on you.
  let branch = run("git rev-parse --abbrev-ref HEAD");
  if (branch !== "main" && branch !== "master") {
    if (allowBranch) {
      stdout.write(
        C.yellow(`⚠️  --allow-branch: running against ${branch} (not main/master)\n`) +
          C.dim("  base-branch correctness is on you — if the base is wrong, the output isn't trustworthy\n"),
      );
    } else {
      const target = tryRun("git rev-parse --verify --quiet main")
        ? "main"
        : tryRun("git rev-parse --verify --quiet master")
          ? "master"
          : null;
      if (!target) {
        die(
          `Currently on ${branch}, and no main/master to switch to`,
          "the backfill branch must be based on the main branch (ADR-0025). To really base it on the current branch: --allow-branch",
        );
      }
      run(`git checkout ${target}`);
      stdout.write(
        C.yellow(`⚠️  Was on ${branch}, auto-switched to ${target} (ADR-0025)\n`) +
          C.dim("  To really run against the original branch: --allow-branch\n"),
      );
      branch = target;
    }
  }

  // Pre-check: does today's branch name already exist? Errors by default (the branch may hold
  // manual L1 edits — auto-deleting could destroy that work); --force-redo explicitly deletes
  // and rebuilds it (ADR-0025).
  const today = new Date().toISOString().slice(0, 10);
  const plannedBranch = `docs/gearbox-backfill-${today}`;
  const branchExists = tryRun(`git rev-parse --verify ${plannedBranch} 2>/dev/null`);
  if (branchExists) {
    if (forceRedo) {
      run(`git branch -D ${plannedBranch}`);
      stdout.write(
        C.yellow(`⚠️  --force-redo: deleted local branch ${plannedBranch}, rebuilding\n`) +
          C.dim("  push will use --force-with-lease to overwrite the remote (if it exists)\n"),
      );
    } else {
      die(
        `Today's branch already exists: ${plannedBranch}`,
        `Already ran once today. Three options:\n` +
          `  1) There are manual edits on that branch → go back to it and continue, don't rerun\n` +
          `  2) Discard and redo → gearbox-update --force-redo (deletes and rebuilds the local branch, --force-with-lease overwrites the remote)\n` +
          `  3) Manual: git branch -D ${plannedBranch}`,
      );
    }
  }

  return { downDir, downAdrDir, branch };
}

// ============== matching algorithm ==============

// For each gearbox ADR, decide whether downstream already has it, and how to backfill it
function matchAdrs(gearboxIndex, downIndex, refreshDrift) {
  const actions = []; // { type: 'skip'|'copy'|'refresh', gearbox, target?, reason? }

  for (const [gearboxNum, gearboxAdr] of gearboxIndex) {
    // 1. slug match (downstream has an ADR with the same slug → already backfilled)
    let slugMatch = null;
    for (const [, downAdr] of downIndex) {
      if (downAdr.slug === gearboxAdr.slug) {
        slugMatch = downAdr;
        break;
      }
    }
    if (slugMatch) {
      // hash drift detection (ADR-0021/0024): the upstream hash recorded in the copy vs
      // upstream's current hash
      const recorded = (slugMatch.content.match(/sha256:([0-9a-f]{12})/) ||
        [])[1];
      const drifted = recorded && recorded !== sha12(gearboxAdr.content);
      if (drifted && refreshDrift) {
        actions.push({
          type: "refresh",
          gearbox: gearboxAdr,
          reason: `drift re-copy: recorded sha256:${recorded} ≠ upstream's current hash, overwriting downstream ADR-${pad4(slugMatch.num)}`,
        });
        continue;
      }
      actions.push({
        type: "skip",
        gearbox: gearboxAdr,
        drifted: Boolean(drifted),
        reason: drifted
          ? `slug already exists (downstream ADR-${pad4(slugMatch.num)}), but upstream has been revised (hash drift) — use --refresh-drift to re-copy`
          : `slug already exists (downstream ADR-${pad4(slugMatch.num)})`,
      });
      continue;
    }

    // 2. provenance match (a downstream ADR header reads "backfilled from gearbox ADR-{num}"
    // → already backfilled)
    let provenanceMatch = null;
    for (const [, downAdr] of downIndex) {
      if (downAdr.provenanceGearboxNum === gearboxNum) {
        provenanceMatch = downAdr;
        break;
      }
    }
    if (provenanceMatch) {
      actions.push({
        type: "skip",
        gearbox: gearboxAdr,
        reason: `downstream ADR-${pad4(provenanceMatch.num)}'s provenance field points to this ADR`,
      });
      continue;
    }

    // 3. missing: copy in under gearbox's original number (no collision — the number stays
    // 1:1 with upstream)
    actions.push({
      type: "copy",
      gearbox: gearboxAdr,
      reason: "missing downstream, copying under the gearbox original number",
    });
  }

  return actions;
}

// ============== copying ==============

// Copy a single ADR + apply the provenance stamp (no renumbering — after the dual-directory
// split, the number is 1:1 with upstream, so ADR-XXXX cross-references never need rewriting)
function transformAdrContent(gearboxAdr) {
  const content0 = gearboxAdr.content;

  // Provenance field (append a machine-generated line if the gearbox ADR doesn't already have one)
  if (gearboxAdr.hasProvenanceField) return content0;

  const gearboxUrl = `${GEARBOX_GITHUB_BASE}/${pad4(gearboxAdr.num)}-${gearboxAdr.slug}.md`;
  // Hash stamp (ADR-0021): the first 12 chars of the upstream file's content sha256 — gearbox-version
  // uses it to detect upstream drift on the copy. The format `sha256:[0-9a-f]{12}` is the
  // contract between the two tools.
  const upstreamHash = sha12(gearboxAdr.content);
  const provenanceLine = `- Provenance: backfilled from [gearbox ADR-${pad4(gearboxAdr.num)}](${gearboxUrl}) (gearbox-update tool sync, upstream sha256:${upstreamHash})`;
  const lines = content0.split("\n");
  let insertAt = 1;
  for (let i = 0; i < Math.min(lines.length, 8); i++) {
    if (/^- Date:/.test(lines[i])) {
      insertAt = i + 1;
      break;
    }
  }
  lines.splice(insertAt, 0, provenanceLine);
  return lines.join("\n");
}

// Supersede link: if this backfill includes gearbox 0012, change downstream 0006's status
// (the number is 1:1 with upstream, so the downstream landing number is always 12; the caller
// only invokes this after confirming this run's toCopy includes 0012)
function applySupersedeLink(downAdrDir) {
  const downstream0006Path = join(downAdrDir, "0006-tiered-change-authority.md");
  if (!existsSync(downstream0006Path)) return null;

  let content = readFileSync(downstream0006Path, "utf8");
  const statusLineMatch = content.match(/^- Status:\s*(.+)$/m);
  if (!statusLineMatch) return null;

  const currentStatus = statusLineMatch[1].trim();
  if (/partially superseded/.test(currentStatus)) {
    return { alreadyApplied: true, newNum: 12 };
  }

  const newStatus = `partially superseded by ADR-0012 (auto-synced by gearbox-update)`;
  content = content.replace(
    /^(- Status:\s*).+$/m,
    `$1${newStatus}`,
  );
  writeFileSync(downstream0006Path, content);
  return { alreadyApplied: false, newNum: 12, file: downstream0006Path };
}

// ============== AGENTS.md report ==============

